# ============================================
# TokenStar AI星球 - Payload CMS 后端环境变量
# 复制此文件为 .env 并修改配置
# ============================================

# 数据库连接（PostgreSQL）
DATABASE_URL=postgresql://strapi_user:strapi_password@127.0.0.1:5432/tokenstar_db

# Payload CMS 密钥（生产环境请修改为随机强密码，至少 32 位）
PAYLOAD_SECRET=tokenstar_ai_planet_secret_2026_change_in_production

# 服务端口
PORT=3000

# 前端域名（用于 CORS 配置）
FRONTEND_URL=http://localhost:3001

# 节点环境（development / production）
NODE_ENV=development
